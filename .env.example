# ═══════════════════════════════════════════════════════════════
# PayerX Deployment Configuration - ARC Testnet
# Based on: https://docs.arc.network/arc/tutorials/deploy-on-arc
# ═══════════════════════════════════════════════════════════════

# 🔑 PRIVATE KEY (Required for deployment)
# ⚠️  NEVER commit this to version control or share publicly!
# Generate one with: cast wallet new
# Then paste your private key here (WITH 0x prefix)
PRIVATE_KEY=0x

# 🌐 ARC TESTNET RPC URLS
# Primary RPC endpoint for ARC Testnet
ARC_TESTNET_RPC_URL=https://rpc.testnet.arc.network

# 🔗 NETWORK CONFIGURATION
ARC_TESTNET_CHAIN_ID=5042002

# ⛽ GAS CONFIGURATION
# ARC uses USDC for gas, target fee is ~$0.01 per transaction
ARC_TESTNET_GAS_PRICE=160000000000
ARC_TESTNET_GAS_LIMIT=10000000

# 💰 FEE CONFIGURATION
# Fee in basis points: 10 = 0.1%, 50 = 0.5%, 100 = 1% (MAX)
FEE_BPS=10

# 📍 FEE COLLECTOR ADDRESS
# Address that receives collected fees
FEE_COLLECTOR=

# 🪙 ARC TESTNET TOKEN ADDRESSES (REAL Circle Contracts)
ARC_USDC=0x3600000000000000000000000000000000000000
ARC_EURC=0x89B50855Aa3bE2F677cD6303Cec089B5F319D72a
ARC_USYC=0xe9185F0c5F296Ed1797AaE4238D26CCaBEadb86C

# 🔄 STABLEFX INFRASTRUCTURE (Phase 2)
STABLEFX_ESCROW=0x867650F5eAe8df91445971f14d89fd84F0C9a9f8
PERMIT2=0x000000000022D473030F116dDEE9F6B43aC78BA3

# 📊 EXPLORER & TOOLS
ARC_TESTNET_EXPLORER=https://testnet.arcscan.app
ARC_FAUCET_URL=https://faucet.circle.com

# 🔑 BLOCK EXPLORER API KEY (Optional)
ARCSCAN_API_KEY=
